<article class="smart-card" style="border: 1px solid #ddd; border-radius: 8px; overflow: hidden; max-width: 300px;">

	{% if imagen_url %}
		<img src="{{ imagen_url }}" alt="{{ titulo }}" style="width: 100%; height: 200px; object-fit: cover;">
	{% endif %}

	<div style="padding: 20px;">
		<h3>{{ titulo }}</h3>

		{% if url %}
			<a href="{{ url }}" class="boton-leer-mas" style="display: inline-block; margin-top: 10px; background: #007bff; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;">
				Leer más
			</a>
		{% endif %}
	</div>
</article>
