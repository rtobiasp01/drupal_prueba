{#
/**
 * @file
 * Template para el componente Hero Banner.
 *
 * Variables disponibles:
 * - titulo: (string) El título principal.
 * - subtitulo: (string) El texto secundario.
 * - url_boton: (string) La ruta del enlace.
 * - texto_boton: (string) El texto del botón.
 */
#}
<div class="hero-banner" style="background: #f4f4f4; padding: 40px; text-align: center;">

	{% if titulo %}
		<h1 class="hero-banner__titulo">{{ titulo }}</h1>
	{% endif %}

	{% if subtitulo %}
		<p class="hero-banner__subtitulo">{{ subtitulo }}</p>
	{% endif %}

	{% if url_boton and texto_boton %}
		<a href="{{ url_boton }}" class="hero-banner__boton" style="padding: 10px 20px; background: blue; color: white; text-decoration: none;">
			{{ texto_boton }}
		</a>
	{% endif %}

</div>
