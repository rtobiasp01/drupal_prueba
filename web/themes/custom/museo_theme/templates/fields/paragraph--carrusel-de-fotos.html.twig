{# Archivo: paragraph--carrusel-de-fotos.html.twig #}

{# 1. Cambiamos la librería a la de Owl Carousel (Asegúrate de que este nombre coincida con tu .libraries.yml) #}
{{ attach_library('museo_theme/owl_carousel') }}

	<div class="mi-carrusel-componente"> {% if content.field_titulo_seccion|render|trim %}
		<h3 class="carrusel-titulo">{{ content.field_titulo_seccion }}</h3>
	{% endif %}

	{# 2. Owl Carousel solo necesita la clase 'owl-carousel' y 'owl-theme' (opcional para estilos base) #}
	<div class="owl-carousel owl-theme">
		{% for key, item in content.field_imagenes_galeria %}
			{% if key|first != '#' %}
				{# 3. En Owl, cada hijo directo del contenedor se convierte en un slide automáticamente #}
				<div class="item">
					{{ item }}
				</div>
			{% endif %}
		{% endfor %}
	</div>
</div>
